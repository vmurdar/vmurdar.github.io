---
import Layout from "../../layouts/Layout.astro";
import { getEntry, render } from "astro:content";
import { SignedIn, SignedOut, UserButton } from '@clerk/astro/components';
import { isProtectedContent } from "../../config/protected-content";
import { sectionKeys, siteMap, type SectionKey, type SiteMapSection } from "../../config/site-map";

export async function getStaticPaths() {
  const paths = [];
  for (const section of sectionKeys) {
    const menu = siteMap[section] as SiteMapSection;
    if (menu.slug) paths.push({ params: { section, slug: menu.slug } });
    if (menu.children) {
      for (const child of menu.children) {
        if (child.slug) paths.push({ params: { section, slug: child.slug } });
      }
    }
  }
  return paths;
}

const { section, slug } = Astro.params;

function isSection(value: string): value is SectionKey {
  return sectionKeys.includes(value as SectionKey);
}

if (!section || !slug || !isSection(section)) {
  return new Response(null, { status: 404 });
}

const entry = await getEntry(section, slug);
if (!entry || entry.data.draft) {
  return new Response(null, { status: 404 });
}

const isProtected = isProtectedContent(section, slug);
const { Content } = await render(entry);

// Correctly handle the base path for GitHub Pages
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPath = Astro.url.pathname;
const signInPath = `${base}/sign-in?redirect_url=${encodeURIComponent(currentPath)}`;
---

<Layout title={entry.data.title}>
  <header class="mb-8 flex justify-between items-start">
    <div>
      <nav class="breadcrumb">
        <a href={import.meta.env.BASE_URL}>Home</a> / <span class="capitalize">{section}</span> / {entry.data.title}
      </nav>
      <h1 class="text-3xl font-bold text-white">{entry.data.title}</h1>
    </div>
    <!-- Added a User Button so you can see your login status clearly -->
    <SignedIn>
      <UserButton afterSignOutUrl={import.meta.env.BASE_URL} />
    </SignedIn>
  </header>

  <div class="prose prose-lg prose-invert max-w-none">
    {isProtected ? (
      <>
        <SignedIn>
          <Content />
        </SignedIn>

        <SignedOut>
          <div class="bg-zinc-800 p-12 rounded-2xl border border-zinc-700 text-center shadow-2xl">
            <div class="text-5xl mb-4">🔒</div>
            <h2 class="text-white mt-0">Protected Content</h2>
            <p class="text-zinc-400 mb-8">This section (meTube) requires an account to view.</p>
            <a 
              href={signInPath} 
              class="inline-block bg-blue-600 hover:bg-blue-500 text-white px-8 py-3 rounded-xl font-bold transition-all transform hover:scale-105"
            >
              Sign In to View
            </a>
          </div>
        </SignedOut>
      </>
    ) : (
      <Content />
    )}
  </div>

  <div class="mt-12 pt-8 border-t border-zinc-700">
    <a href={import.meta.env.BASE_URL} class="back-link">&larr; Back to Home</a>
  </div>
</Layout>