---
import Layout from '../layouts/Layout.astro';
import { Carousel } from '../components/Carousel';

const imageModules = import.meta.glob<{ default: { src: string } }>(
  "../assets/carousel/*.{jpg,jpeg,png,webp,avif}",
  { eager: true }
);

// REFACTORED: Create an object with both the source and a clean name
const images = Object.entries(imageModules).map(([path, mod]) => {
  const fileName = path.split('/').pop()?.split('.')[0] || "Carousel image";
  // Replace hyphens/underscores with spaces for better screen reader flow
  const altText = fileName.replace(/[-_]/g, ' ');
  
  return {
    src: mod.default.src,
    alt: altText
  };
});
---

<Layout title="The World according to Me">
  <header class="mb-8 text-center">
    <h1 class="text-3xl font-bold mb-4">Maps and stuff</h1>
  </header>

  <div class="mb-12">
    <Carousel client:visible />
  </div>
</Layout>