---
import Layout from "../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { SignedIn, SignedOut, UserButton } from '@clerk/astro/components';
import { existsSync, statSync } from "node:fs";
import Instagram from "../components/Instagram.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  
  return pages.map(page => ({
    params: { slug: page.id }, // page.id will look like "health/hiit" or "meTube/clips"
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);

// 1. Extract protection status from frontmatter
const isProtected = page.data.isProtected;

// 2. Extract the section name for the breadcrumb (e.g., "health" from "health/hiit")
const sectionName = page.id.split('/')[0];

// 3. File System logic for the "last saved" footer
// Astro 5 glob loader usually provides the exact physical path in page.filePath
const contentFileCandidates = page.filePath ? [page.filePath] : [
  `src/content/pages/${page.id}.mdx`,
  `src/content/pages/${page.id}.md`,
];

const contentFilePath = contentFileCandidates.find((candidate) => existsSync(candidate));
const lastSavedDate = contentFilePath ? statSync(contentFilePath).mtime : null;
const lastSavedText = lastSavedDate
  ? new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long", day: "numeric" }).format(lastSavedDate)
  : null;

// 4. Clerk redirect logic
const currentPath = Astro.url.pathname;
const signInPath = `/sign-in?redirect_url=${encodeURIComponent(currentPath)}&after_sign_in_url=${encodeURIComponent(currentPath)}&after_sign_up_url=${encodeURIComponent(currentPath)}&sign_in_force_redirect_url=${encodeURIComponent(currentPath)}&sign_up_force_redirect_url=${encodeURIComponent(currentPath)}`;
---

<Layout title={page.data.title}>
  <header class="mb-8 flex justify-between items-start">
    <div>
      <nav class="breadcrumb">
        <a href={import.meta.env.BASE_URL}>Home</a> / <span class="capitalize">{sectionName}</span> / {page.data.title}
      </nav>
      <h1 class="text-3xl font-bold text-white">{page.data.title}</h1>
    </div>
    <SignedIn>
      <UserButton afterSignOutUrl={import.meta.env.BASE_URL} />
    </SignedIn>
  </header>

  <div class="prose prose-lg prose-invert max-w-none">
    {isProtected ? (
      <>
        <SignedIn>
          <Content components={{ Instagram }}/>
        </SignedIn>

        <SignedOut>
          <div class="bg-zinc-800 p-12 rounded-2xl border border-zinc-700 text-center shadow-2xl">
            <div class="text-5xl mb-4">🔒</div>
            <h2 class="text-white mt-0">Protected Content</h2>
            <p class="text-zinc-400 mb-8">This section requires an account to view.</p>
            <a 
              href={signInPath}
              class="inline-block bg-blue-600 hover:bg-blue-500 text-white px-8 py-3 rounded-xl font-bold transition-all transform hover:scale-105"
            >
              Sign In to View
            </a>
          </div>
        </SignedOut>
      </>
    ) : (
      <Content components={{ Instagram }}/>
    )}
  </div>

  <div class="mt-12 pt-8 border-t border-zinc-700">
    {lastSavedText && <p class="mb-4 text-right text-sm text-zinc-500">&copy; {lastSavedText}</p>}
    <a href={import.meta.env.BASE_URL} class="back-link">&larr; Back to Home</a>
  </div>
</Layout>